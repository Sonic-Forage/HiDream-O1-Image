# HiDream-O1-Image checkpoint (required if --model_path is not passed)
HIDREAM_MODEL_PATH=/path/to/HiDream-O1-Image
HIDREAM_MODEL_TYPE=full

# Flask host / port
HIDREAM_HOST=0.0.0.0
HIDREAM_PORT=7860

# Local prompt-refiner backend (Gemma)
HIDREAM_AGENT_MODEL=google/gemma-4-31B-it

# Optional: default OpenAI-compatible refiner credentials
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-xxx
